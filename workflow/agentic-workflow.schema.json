{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agenticworkflow.dev/schemas/agentic-workflow.schema.json",
  "title": "Agentic Workflow Manifest",
  "type": "object",
  "required": ["name", "version", "principles", "roles", "phases", "qualityGates"],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "principles": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "roles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "mission", "may", "mustNot", "handoffTo"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
          "mission": { "type": "string", "minLength": 1 },
          "may": { "type": "array", "items": { "type": "string" } },
          "mustNot": { "type": "array", "items": { "type": "string" } },
          "tools": { "type": "array", "items": { "type": "string" } },
          "outputs": { "type": "array", "items": { "type": "string" } },
          "handoffTo": { "type": "string" }
        }
      }
    },
    "phases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "role", "entryCriteria", "exitCriteria"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
          "role": { "type": "string" },
          "entryCriteria": { "type": "array", "items": { "type": "string" } },
          "exitCriteria": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "qualityGates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description", "evidence"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
          "description": { "type": "string" },
          "evidence": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
